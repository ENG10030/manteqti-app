# ===========================================
# متغيرات البيئة لمشروع منطقتي
# ===========================================

# Pooler - Transaction Mode (للتطبيق)
DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Pooler - Session Mode (للـ Migrations)
DIRECT_DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@aws-1-eu-west-1.pooler.supabase.com:5432/postgres"

# ===========================================
# Cloudinary - للتخزين السحابي
# ===========================================
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ===========================================
# الأمان
# ===========================================
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ===========================================
# بيانات المطور
# ===========================================
DEVELOPER_EMAIL="your-email@example.com"
DEVELOPER_PASSWORD="your-password"

# ===========================================
# مفتاح Cron Job
# ===========================================
CRON_SECRET="your-cron-secret"
