// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===========================================
// نموذج المستخدم
// ===========================================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  phone         String?
  role          String    @default("user") // "user" or "developer"
  image         String?
  isBlocked     Boolean   @default(false)
  blockedAt     DateTime?
  blockedBy     String?   // ID of developer who blocked
  blockedReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // العلاقات
  apartments         Apartment[]
  blockedContents    BlockedContent[]
  sessions           Session[]
  accounts           Account[]

  @@map("users")
}

// ===========================================
// نموذج العقار
// ===========================================
model Apartment {
  id              String    @id @default(cuid())
  title           String
  description     String?
  price           Float?
  area            Float?
  rooms           Int?
  bathrooms       Int?
  address         String?
  city            String?
  neighborhood    String?
  type            String?   // "sale", "rent", etc.
  status          String    @default("pending") // "pending", "approved", "rejected"
  images          String?   // JSON array of image URLs
  
  // التمييز
  isFeatured      Boolean   @default(false)
  featuredType    String?   // "featured" or "featured_plus"
  featuredBy      String?   // ID of developer who featured
  featuredAt      DateTime?
  
  // الموافقة
  approvedBy      String?   // ID of developer who approved
  approvedAt      DateTime?
  
  // الملكية
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // إخفاء المحتوى المحظور
  isHidden        Boolean   @default(false) // مخفي بسبب حظر المستخدم
  hiddenAt        DateTime?
  
  // العلاقات
  creator         User      @relation(fields: [createdBy], references: [id])
  blockedContents BlockedContent[]

  @@index([status])
  @@index([isFeatured, featuredType])
  @@index([createdBy])
  @@map("apartments")
}

// ===========================================
// نموذج المحتوى المحظور
// ===========================================
model BlockedContent {
  id              String   @id @default(cuid())
  userId          String   // المستخدم المحظور
  apartmentId     String   // العقار المخفي
  blockedBy       String   // المطور الذي حظر
  action          String   // "hidden", "deleted"
  canRestore      Boolean  @default(true) // هل يمكن استعادته
  createdAt       DateTime @default(now())
  
  // العلاقات
  user            User      @relation(fields: [userId], references: [id])
  apartment       Apartment @relation(fields: [apartmentId], references: [id])

  @@map("blocked_contents")
}

// ===========================================
// نماذج NextAuth
// ===========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
