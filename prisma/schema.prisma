// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  identifier String      @unique
  name       String
  password   String
  phone      String?
  email      String?
  otp        String?
  otpExpires DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  inquiries  Inquiry[]
  payments   Payment[]
}

model Apartment {
  id              String      @id @default(cuid())
  title           String
  price           Int
  area            String
  bedrooms        Int
  bathrooms       Int
  description     String
  ownerPhone      String
  mapLink         String
  imageUrl        String?
  images          String?
  videoUrl        String?
  videos          String?
  amenities       String?
  featured        Boolean     @default(false)
  type            String
  status          String      @default("pending")
  statusChangedAt DateTime?
  views           Int         @default(0)
  paymentRef      String?
  agreementStatus String?
  createdBy       String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  inquiries       Inquiry[]
  
  @@map("apartments")  
}

model Inquiry {
  id               String    @id @default(cuid())
  apartmentId      String
  userId           String?
  name             String
  email            String
  phone            String
  message          String
  lifecycleStatus  String    @default("New")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  apartment        Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user             User?     @relation(fields: [userId], references: [id])
  payment          Payment?
}

model Payment {
  id             String    @id @default(cuid())
  inquiryId      String    @unique
  method         String
  status         String    @default("Pending")
  inquiryStatus  String    @default("Contacted")
  amount         Int
  transactionRef String?
  paymentLink    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  inquiry        Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?
}

model OtpCode {
  id        String   @id @default(cuid())
  code      String
  email     String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model OperationLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  userId      String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model Settings {
  id                  String   @id @default(cuid())
  contactFee          Int      @default(50)
  featuredFee         Int      @default(100)
  premiumFee          Int      @default(200)
  saleDisplayFee      Int      @default(100)
  rentDisplayFee      Int      @default(75)
  otherServicesFee    Int      @default(50)
  highlightFee        Int      @default(150)
  priorityListingFee  Int      @default(200)
  verifiedListingFee  Int      @default(250)
  currency            String   @default("ج.م")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
}

model SecurityLog {
  id          String   @id @default(cuid())
  action      String
  identifier  String
  ipAddress   String?
  userAgent   String?
  details     String?
  createdAt   DateTime @default(now())
}
