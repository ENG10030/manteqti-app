// PostgreSQL Schema for Supabase
// مخطط قاعدة البيانات لـ Supabase

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  identifier String      @unique
  name       String
  password   String
  phone      String?
  email      String?
  otp        String?
  otpExpires DateTime?
  isBlocked  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  inquiries  Inquiry[]
  payments   Payment[]
  sessions   Session[]
  likes      Like[]
  comments   Comment[]
  sentMessages     Message[]  @relation("SentMessages")
  receivedMessages Message[]  @relation("ReceivedMessages")
  blockedRecords   BlockedUser[]
  editRequests      PropertyEditRequest[]
}

model Apartment {
  id              String      @id @default(cuid())
  title           String
  price           Int
  area            String
  bedrooms        Int
  bathrooms       Int
  description     String
  ownerPhone      String
  mapLink         String
  imageUrl        String?
  images          String?     // JSON array of image URLs
  videoUrl        String?
  videos          String?     // JSON array of video URLs
  amenities       String?     // JSON array of amenities
  featured        Boolean     @default(false)
  type            String      // 'rent' or 'sale'
  status          String      @default("pending") // pending, available, preview, reserved, unavailable, sold, rented
  statusChangedAt DateTime?
  views           Int         @default(0)
  paymentRef      String?
  agreementStatus String?
  createdBy       String?     // User ID who created this apartment
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  inquiries       Inquiry[]
  likes           Like[]
  comments        Comment[]
  editRequests    PropertyEditRequest[]
  
  // VIP والمميز
  isFeatured      Boolean     @default(false)
  isVip           Boolean     @default(false)
  featuredUntil   DateTime?
}

model Inquiry {
  id               String    @id @default(cuid())
  apartmentId      String
  userId           String?
  name             String
  email            String
  phone            String
  message          String
  lifecycleStatus  String    @default("New") // New, Contacted, Converted, Lost
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  apartment        Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user             User?     @relation(fields: [userId], references: [id])
  payment          Payment?
}

model Payment {
  id             String    @id @default(cuid())
  inquiryId      String    @unique
  method         String    // Visa, Mastercard, InstaPay, Cash, Manual
  status         String    @default("Pending") // Paid, Pending, Failed
  inquiryStatus  String    @default("Contacted")
  amount         Int
  transactionRef String?
  paymentLink    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  inquiry        Inquiry   @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id])
  userId         String?
}

model OtpCode {
  id        String   @id @default(cuid())
  code      String
  email     String
  createdAt DateTime @default(now())
  expiresAt DateTime
}

model OperationLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  userId      String?
  details     String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model Settings {
  id                  String   @id @default(cuid())
  contactFee          Int      @default(50)
  featuredFee         Int      @default(100)
  premiumFee          Int      @default(200)
  saleDisplayFee      Int      @default(100)
  rentDisplayFee      Int      @default(75)
  otherServicesFee    Int      @default(50)
  highlightFee        Int      @default(150)
  priorityListingFee  Int      @default(200)
  verifiedListingFee  Int      @default(250)
  currency            String   @default("ج.م")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SecurityLog {
  id          String   @id @default(cuid())
  action      String
  identifier  String
  ipAddress   String?
  userAgent   String?
  details     String?
  createdAt   DateTime @default(now())
}

// نظام الإعجابات
model Like {
  id          String   @id @default(cuid())
  apartmentId String
  userId      String
  createdAt   DateTime @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([apartmentId, userId])
}

// نظام التعليقات مع الموافقة
model Comment {
  id          String   @id @default(cuid())
  apartmentId String
  userId      String
  content     String
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  approvedBy  String?
  approvedAt  DateTime?
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// نظام الرسائل بين المستخدمين والمطور
model Message {
  id           String   @id @default(cuid())
  senderId     String
  receiverId   String?  // null للمطور (رسالة للمطور)
  content      String
  isRead       Boolean  @default(false)
  createdAt    DateTime @default(now())
  sender       User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver     User?    @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

// نظام الحظر
model BlockedUser {
  id          String   @id @default(cuid())
  userId      String
  reason      String?
  blockedAt   DateTime @default(now())
  blockedBy   String?  // المطور الذي قام بالحظر
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// نظام استعادة كلمة المرور
model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// نظام طلبات تعديل العقارات بعد النشر
model PropertyEditRequest {
  id              String   @id @default(cuid())
  apartmentId     String
  userId          String   // الناشر الذي طلب التعديل
  
  // أنواع التعديلات المطلوبة
  editType        String   // 'images' | 'videos' | 'price' | 'status' | 'multiple'
  
  // البيانات الجديدة (حسب نوع التعديل)
  newImages       String?  // JSON array of new image URLs
  newVideos       String?  // JSON array of new video URLs
  newPrice        Int?
  newStatus       String?
  
  // وصف التعديل
  description     String?  // سبب التعديل أو ملاحظات
  
  // حالة الطلب
  status          String   @default("pending") // pending, approved, rejected
  
  // بيانات المراجعة
  reviewedBy      String?  // المطور الذي راجع الطلب
  reviewedAt      DateTime?
  reviewNotes     String?  // ملاحظات المطور عند القبول أو الرفض
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  apartment       Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
